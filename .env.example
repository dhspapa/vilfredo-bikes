# =============================================================================
# Local development (.env)
# =============================================================================

# Django
DJANGO_SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=
SITE_URL=http://127.0.0.1:8002

# Database (SQLite default for local dev)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# Static files
STATIC_ROOT=staticfiles

# HTTPS redirect (only used when DEBUG=False; leave unset locally)
SECURE_SSL_REDIRECT=False

# Stripe test mode (https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_PUBLIC_KEY=pk_test_your_public_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Local dev only: mark reservations paid from success page without webhook
LOCAL_STRIPE_SUCCESS_FALLBACK=False

# Email (leave EMAIL_HOST empty in dev to print emails to the console)
EMAIL_BACKEND=
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=bikes@example.com
ADMIN_NOTIFICATION_EMAIL=owner@example.com

# =============================================================================
# PythonAnywhere production template (copy to server .env — test Stripe first)
# =============================================================================
#
# DJANGO_SECRET_KEY=generate-a-long-random-secret
# DEBUG=False
# ALLOWED_HOSTS=yourusername.pythonanywhere.com
# CSRF_TRUSTED_ORIGINS=https://yourusername.pythonanywhere.com
# SITE_URL=https://yourusername.pythonanywhere.com
# SECURE_SSL_REDIRECT=False
#
# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=db.sqlite3
# STATIC_ROOT=staticfiles
#
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLIC_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# LOCAL_STRIPE_SUCCESS_FALLBACK=False
#
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=bikes@example.com
# ADMIN_NOTIFICATION_EMAIL=owner@example.com
#
# Webhook (test): https://yourusername.pythonanywhere.com/stripe/webhook/
#
# See PYTHONANYWHERE.md and PYTHONANYWHERE_CHECKLIST.md

# =============================================================================
# VPS / custom domain (after PythonAnywhere test passes)
# =============================================================================
#
# DJANGO_SECRET_KEY=generate-a-long-random-secret
# DEBUG=False
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# SITE_URL=https://yourdomain.com
# SECURE_SSL_REDIRECT=True
#
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=vilfredo_bikes
# DB_USER=vilfredo_bikes
# DB_PASSWORD=strong-database-password
# DB_HOST=localhost
# DB_PORT=5432
# STATIC_ROOT=staticfiles
#
