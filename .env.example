# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=bikes@yourdomain.com
# EMAIL_HOST_PASSWORD=smtp-password
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=bikes@yourdomain.com
