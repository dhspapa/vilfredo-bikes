msgstr "Ηλεκτρικό"

msgid "City"
msgstr "Πόλης"

msgid "Easy"
msgstr "Εύκολη"

msgid "Moderate"
msgstr "Μέτρια"

msgid "Challenging"
msgstr "Απαιτητική"

msgid "Payment cancelled"
msgstr "Η πληρωμή ακυρώθηκε"

msgid "Pickup instructions:"
msgstr "Οδηγίες παραλαβής:"

msgid "The bike is available at your accommodation from the first rental day."
msgstr "Το ποδήλατο είναι διαθέσιμο στο κατάλυμά σας από την πρώτη ημέρα ενοικίασης."

msgid "You will receive the lock/code details by message or at the property."
msgstr "Τα στοιχεία κλειδαριάς/κωδικού θα σας δοθούν με μήνυμα ή στο κατάλυμα."

msgid "Please check the bike before use and report any visible damage immediately."
msgstr "Ελέγξτε το ποδήλατο πριν τη χρήση και αναφέρετε άμεσα οποιαδήποτε εμφανή φθορά."

msgid "Return instructions:"
msgstr "Οδηγίες επιστροφής:"

msgid "Return the bike to the same pickup location before the end of your rental period."
msgstr "Επιστρέψτε το ποδήλατο στο ίδιο σημείο παραλαβής πριν τη λήξη της περιόδου ενοικίασης."

msgid "Lock the bike securely."
msgstr "Κλειδώστε το ποδήλατο σωστά."

msgid "Late return may affect the refundable security deposit."
msgstr "Η καθυστερημένη επιστροφή μπορεί να επηρεάσει την επιστροφή της εγγύησης."

msgid "Rent a bike during your stay at %(property)s."
msgstr "Ενοικιάστε ποδήλατο κατά τη διαμονή σας στο %(property)s."

msgid "Choose a bike"
msgstr "Επιλέξτε ποδήλατο"

msgid "For guests staying at %(property)s."
msgstr "Για επισκέπτες που διαμένουν στο %(property)s."

msgid "%(bike)s rental"
msgstr "Ενοικίαση %(bike)s"

